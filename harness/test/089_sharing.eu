##
## 089: Thunk sharing through data constructors
##
## Tests that thunk memoisation is preserved when pattern-matching
## on data constructors (cons cells). When the shared-env fix is in
## place, each element of a lazy list is evaluated at most once
## regardless of how many traversals are performed.
##
## Without the fix, certain traversals that force thunks would not
## propagate the evaluated value back to the original constructor's
## environment frame, causing re-evaluation on subsequent access.
##

## Build a reusable list binding and traverse it multiple times.
## Verifies that repeated traversals yield consistent results.

shared-list: take(20, iterate((+ 1), 0))

sharing-checks: {
  trues: [
    ## Sum of 0..19 = 190
    (shared-list sum) = 190,

    ## Length must be 20
    (shared-list count) = 20,

    ## Sum of first 10 elements (0..9) = 45
    (shared-list take(10) sum) = 45,

    ## Two traversals of the same binding agree
    (shared-list sum) = (shared-list sum)
  ]
}

## A list defined via doubled iterate: [0,4,8,12,16]
doubled-checks: {
  dl: take(5, iterate((+ 2), 0)) map((_ * 2))
  trues: [
    (dl sum) = 40,
    (dl count) = 5,
    (dl sum) = (dl sum)
  ]
}

pass: [
  sharing-checks.trues all-true?,
  doubled-checks.trues all-true?
] all-true?

RESULT: if(pass, :PASS, :FAIL)
