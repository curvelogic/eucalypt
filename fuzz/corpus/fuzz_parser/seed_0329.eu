# Row variable bound to empty when input has no extra fields.
# extend is annotated {x: number, ..r} -> {x: number, y: string, ..r}.
# Called with {x: 1} only, r is bound to {} (empty).
# Result type is closed {x: number, y: string}.
# result.w accesses a field not present in the closed result type — warning expected.
` { type: "!{{x: number, ..r}} -> {{x: number, y: string, ..r}}" }
extend(base): base { y: "hello" }

result: extend({ x: 1 })
check: result.w
