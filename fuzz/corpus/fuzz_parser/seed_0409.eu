# Regression: a docstring on a types: alias entry must not disable
# the alias (GH #810).  The Meta wrapper around the alias value
# should be unwrapped before extracting the type string.
{ types: {
    ` "The permitted actions."
    Action: c"\"block\" | \"log\""
} }

` { type: "Action -> symbol" }
f(a): :ok

# This should warn: "blk" is not in "block" | "log"
bad: f("blk")
