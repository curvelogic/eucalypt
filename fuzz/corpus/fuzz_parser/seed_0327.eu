# Applying a typed record to an untyped (any) arg — gradual boundary.
# No warning: the RHS is unannotated, so no type check is possible.
` { type: "number -> number" }
inc(x): x + 1

base: { a: 1 }
# rhs has no type annotation; treated as any — no warning.
dynamic-rhs(input): input
extended: base dynamic-rhs(42)
result: inc(extended.a)
