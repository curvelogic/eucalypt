"Thunk sharing through data constructors. Tests that thunk memoisation is preserved when pattern-matching on data constructors (cons cells)."

` "Build a reusable list binding and traverse it multiple times. Verifies that repeated traversals yield consistent results."
shared-list: take(20, iterate(+ 1, 0))

sharing-checks: {
  trues: [
    # Sum of 0..19 = 190
    shared-list sum //= 190,

    # Length must be 20
    shared-list count //= 20,

    # Sum of first 10 elements (0..9) = 45
    shared-list take(10) sum //= 45,

    # Two traversals of the same binding agree
    (shared-list sum) = (shared-list sum)
  ]
}

` "A list defined via doubled iterate"
doubled-checks: {
  dl: take(5, iterate(+ 2, 0)) map(* 2)
  trues: [
    dl sum //= 40,
    dl count //= 5,
    (dl sum) = (dl sum)
  ]
}

` "Sharing stress test using iterate with a larger list. Without thunk sharing, each thunk inside a cons cell would be re-evaluated on every traversal."
large-list: take(100, iterate(+ 1, 0))

stress-checks: {
  # 0..99 sum = 4950
  total: large-list sum
  # count
  n: large-list count
  trues: [
    total //= 4950,
    n //= 100,
    # Three independent traversals must all agree
    (large-list sum) = total,
    (large-list sum) = total,
    (large-list sum) = total
  ]
}

pass: [
  sharing-checks.trues all-true?,
  doubled-checks.trues all-true?,
  stress-checks.trues all-true?
] all-true?

RESULT: if(pass, :PASS, :FAIL)
