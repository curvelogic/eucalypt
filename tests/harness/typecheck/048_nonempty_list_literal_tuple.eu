# Non-empty list literals synthesise as Tuple up to LIST_TUPLE_CAP=16.
# A Tuple([number]) is a subtype of NonEmpty(number) and of List(number),
# so `head` accepts it without a warning.

` { type: "number" }
first-of-singleton: [42] head

# A heterogeneous 2-element list synthesises as Tuple([number, string]).
# `head` gives the precise first element type: number.
` { type: "number" }
pair-head: [42, "hello"] head
