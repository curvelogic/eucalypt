# Union subtraction in false branch.
# `x` is `number | string | null`. After null?(x) in the condition:
# - true branch: x is `null`
# - false branch: x is `number | string` (null subtracted)
` { type: "(number | string | null) → string" }
describe(x): if(x null?, "nothing", if(x string?, x, str(x)))

result: describe(42)
