"Test deep merge (<<) with dynamically-constructed blocks. The block() function constructs blocks from lists of [k, v] pairs. Deep merge must handle these correctly, even though their keys may be boxed symbols rather than raw symbol natives."

# Static blocks (should already work)
static-merge: {
  eq1: {} << {} = {}
  eq2: {a: 1} << {b: 2} = {a: 1 b: 2}
  eq3: {a: 1} << {a: 2} = {a: 2}
  eq4: {a: {x: 1}} << {a: {x: 2}} = {a: {x: 2}}
}

# Dynamically-constructed blocks via block()
dyn-a: [[:a, 1], [:b, 2]] block
dyn-b: [[:b, 3], [:c, 4]] block

dynamic-merge: {
  # merge() should work with dynamic blocks
  eq1: merge(dyn-a, dyn-b) = {a: 1 b: 3 c: 4}

  # deep merge (<<) with dynamic blocks
  eq2: dyn-a << dyn-b = {a: 1 b: 3 c: 4}

  # deep merge: one static, one dynamic
  eq3: {a: 1 b: 2} << dyn-b = {a: 1 b: 3 c: 4}
  eq4: dyn-a << {b: 3 c: 4} = {a: 1 b: 3 c: 4}

  # deep merge with nested blocks (one level dynamic)
  eq5: {x: dyn-a} << {x: dyn-b} = {x: {a: 1 b: 3 c: 4}}

  # deep merge: dynamic blocks with sub-blocks
  eq6: ([[:a, {x: 1}]] block) << ([[:a, {x: 2}]] block) = {a: {x: 2}}
}

pass: [
    static-merge elements map(value) all-true?,
    dynamic-merge elements map(value) all-true?
  ] all-true?

RESULT: if(pass, :PASS, :FAIL)
