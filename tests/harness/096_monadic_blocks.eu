"Monadic block expressions. A bracket pair defined with an empty block as its parameter gains a monad spec. A bracket block expression desugars to nested bind and return calls."

` "Identity monad: bind(ma, f) = f(ma), return(a) = a. Under the identity monad the block expressions are equivalent to let-bindings."
id-bind(ma, f): f(ma)
id-return(a): a

⟦{}⟧: { :monad bind: id-bind  return: id-return }

` "Maybe monad implemented as optional lists: Just(a) = [a], Nothing = []. bind([a], f) = f(a), bind([], f) = []. return(a) = [a]."
maybe-bind(ma, f): if(ma = [], [], f(ma head))
maybe-return(a): [a]

⌈{}⌉: { :monad bind: maybe-bind  return: maybe-return }

tests: {

  ` "Identity monad — single declaration"
  id-single: {
    ` "return wraps a literal"
    a: ⟦ r: 42 ⟧.r //= 42
    ` "return wraps an expression"
    b: ⟦ r: 1 + 2 ⟧.r //= 3
  }

  ` "Identity monad — two declarations"
  id-two: {
    ` "bind a value then return computed expression"
    a: ⟦ x: 10  r: x + 5 ⟧.r //= 15
    ` "bind a string and reference it"
    b: ⟦ s: "hello"  r: s ⟧.r //= "hello"
  }

  ` "Identity monad — three declarations"
  id-three: {
    ` "bind two values and combine them"
    a: ⟦ a: 1  b: 2  r: a + b ⟧.r //= 3
    ` "bind two values and use only first"
    b: ⟦ a: 7  b: 3  r: a ⟧.r //= 7
  }

  ` "Maybe monad — value present"
  maybe-just: {
    ` "bind through two Just values and return computed expression"
    a: ⌈ x: [1]  y: [2] ⌉.(x + y) //= [3]
  }

  ` "Maybe monad — short-circuits on Nothing"
  maybe-nothing: {
    ` "bind with first argument Nothing"
    a: ⌈ x: []  y: [2] ⌉.(x + y) //= []
    ` "bind with second argument Nothing"
    b: ⌈ x: [1]  y: [] ⌉.(x + y) //= []
  }

}

RESULT: tests values map(values) map(all-true?) all-true? then(:PASS, :FAIL)
