# Regression: plain document with string values rendered in place
# (eu-u2vn.1) — exercises the single-compile render path that replaces
# the double-compile workaround.  Strings are the values most likely
# to expose stale-pointer hazards after a headless run.

greeting: "hello"
farewell: "goodbye"
composed: "{greeting}, world"
counts: ["one", "two", "three"]
nested: { a: "alpha", b: "beta" }

RESULT: (greeting = "hello" && farewell = "goodbye" && composed = "hello, world" && counts = ["one", "two", "three"]) then(:PASS, :FAIL)
