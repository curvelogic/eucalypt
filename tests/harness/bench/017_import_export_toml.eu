{ import: "data=017_fixture.toml"
  doc: "Import -> transform -> export benchmark, TOML variant (workload class I, the product core). Reads a ~185KB TOML fixture (1600 flat records, array-of-tables) through the serde import path, then reshapes each record (rename fields, merge defaults, derive a score), filters and reduces -- the read-a-TOML/reshape-it/emit-YAML workload, which had no engine benchmark before eu-2sa6.6. The reshape is repeated over several rounds to clear >1.5s (the per-record reshape is O(n^2), the shared fold/env-walk ceiling). The fixture is generated by gen/gen_import_fixtures.py (not hand-edited). IMPORTANT: record count is deliberately capped at 1600 -- above ~1900 full-schema TOML records the BYTECODE engine panics with 'bytecode: invalid opcode' on the import (a real P1 defect; the code section from the embedded literal overruns a jump-offset width). YAML nests into smaller scopes and survives to higher N. See PROTOCOL.md section 6. Runs >1.5s on the faster engine. To emit YAML in the runner: eu -x yaml -t bench-import-toml <file>." }

# Defaults every record is layered on top of.
` :suppress
defaults: { region: "global"  priority: 5  healthy: true }

# Reshape one record: rename id/name, keep zone/kind, derive a score
# (TOML records are flat, so cpu is a top-level field), then layer the
# record fields on top of the defaults block.
reshape(r): defaults << {
  uid: r.id
  title: r.name
  zone: r.zone
  kind: r.kind
  score: (r.weight * 2) + r.cpu
}

enabled?(r): r.enabled
get-score(r): r.score

# One reshape pass: import -> filter -> reshape -> reduce (score sum).
reshape-round(_r): data.records filter(enabled?) map(reshape) map(get-score) sum

` :suppress
kept: data.records filter(enabled?) map(reshape)

key-count: kept count
round-total: range(0, 12) map(reshape-round) sum

` { target: :bench-import-toml
    verify: ["default-expectation"] }
bench-import-toml: {
  records: key-count
  total: round-total
  RESULT: if(key-count = 1066,
             if(round-total = 2859012, :PASS, :FAIL),
             :FAIL)
}
