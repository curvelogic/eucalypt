# 16 keys spread across each table (average find depth ~N/2).
` :suppress
keys40: [:k000, :k003, :k005, :k008, :k010, :k013, :k016, :k018, :k021, :k023, :k026, :k029, :k031, :k034, :k036, :k039]

` :suppress
keys250: [:k000, :k017, :k033, :k050, :k066, :k083, :k100, :k116, :k133, :k149, :k166, :k183, :k199, :k216, :k232, :k249]

# One iteration: sum 16 dynamic lookups into the block.
add-lookup(b, acc, k): acc + lookup(k, b)
sum-sample(b, ks, _r): ks foldl(add-lookup(b), 0)

# M distinct rounds (the ignored round index forces 130 separate
# evaluations rather than one memoised thunk), summed.
` :suppress
total40: range(0, 130) map(sum-sample(big40, keys40)) sum

` :suppress
total250: range(0, 130) map(sum-sample(big250, keys250)) sum

