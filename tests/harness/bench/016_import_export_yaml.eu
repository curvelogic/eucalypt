{ import: "data=016_fixture.yaml"
  doc: "Import -> transform -> export benchmark, YAML variant (workload class I, the product core). Reads a ~265KB YAML fixture (1600 records with nested maps and lists) through the serde import path, then reshapes each record (rename fields, merge defaults, derive a score), filters and reduces -- the read-a-YAML/reshape-it/emit-JSON workload eucalypt exists for, which had no engine benchmark before eu-2sa6.6. The reshape is repeated over several rounds to clear >1.5s (the per-record reshape is O(n^2), the shared fold/env-walk ceiling). The fixture is generated by gen/gen_import_fixtures.py (not hand-edited). Record count is kept modest and symmetric with the TOML variant (017) so both stay below the bytecode large-TOML-import panic. Runs >1.5s on the faster engine. To emit JSON in the runner: eu -x json -t bench-import-yaml <file>." }

# Defaults every record is layered on top of.
` :suppress
defaults: { region: "global"  priority: 5  healthy: true }

# Reshape one record: rename id/name, keep zone/kind, derive a score,
# then layer the record fields on top of the defaults block.
reshape(r): defaults << {
  uid: r.id
  title: r.name
  zone: r.zone
  kind: r.kind
  score: (r.weight * 2) + r.limits.cpu
}

enabled?(r): r.enabled
get-score(r): r.score

# One reshape pass: import -> filter -> reshape -> reduce (score sum).
# The ignored round index forces separate evaluations rather than one
# memoised thunk, so the pass runs once per round.
reshape-round(_r): data.records filter(enabled?) map(reshape) map(get-score) sum

` :suppress
kept: data.records filter(enabled?) map(reshape)

key-count: kept count
round-total: range(0, 12) map(reshape-round) sum

` { target: :bench-import-yaml
    verify: ["default-expectation"] }
bench-import-yaml: {
  records: key-count
  total: round-total
  RESULT: if(key-count = 1066,
             if(round-total = 2859012, :PASS, :FAIL),
             :FAIL)
}
